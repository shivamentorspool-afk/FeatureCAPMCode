{
  "name": "datasphere-feature-analytic",
  "version": "1.0.0",
  "description": "CAPM Application for SAP Datasphere Feature Analytic Model Integration",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "cds watch",
    "build": "cds build --production",
    "deploy": "cf push"
  },
  "dependencies": {
    "@sap/cds": "^7.9.0",
    "@sap/cds-dk": "^7.9.0",
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "qs": "^6.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": ":memory:"
        }
      }
    },
    "server": {
      "port": 4004
    }
  }
}